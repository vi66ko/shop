<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="800.0" prefWidth="1280.0" stylesheets="@../styles/global.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.vstamenov.shop.controller.elements.RegisterController">
    <Label layoutX="568.0" layoutY="253.0" text="Creating account">
        <font>
            <Font size="26.0" />
        </font>
    </Label>
    <VBox alignment="CENTER" layoutX="505.0" layoutY="326.0" spacing="20.0" xmlns="http://javafx.com/javafx/21.0.6" xmlns:fx="http://javafx.com/fxml/1">
        <children>
            <HBox alignment="CENTER" spacing="30.0" HBox.hgrow="ALWAYS">
                <ImageView fitHeight="75.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../icons/list-signs-svgrepo-com.png" />
                    </image>
                </ImageView>
                <Label alignment="TOP_CENTER" text="Shop">
                    <font>
                        <Font size="36.0" />
                    </font>
                </Label>
            </HBox>
            <HBox alignment="CENTER_LEFT" layoutX="50.0" layoutY="30.0" spacing="30.0">
                <children>
                    <Label text="Username" />
                    <TextField fx:id="usernameField" />
                </children>
                <VBox.margin>
                    <Insets top="20.0" />
                </VBox.margin>
            </HBox>
            <HBox alignment="CENTER_LEFT" layoutX="50.0" layoutY="105.0" spacing="30.0">
                <children>
                    <Label text="Password " />
                    <PasswordField fx:id="passwordField" />
                </children>
                <VBox.margin>
                    <Insets top="20.0" />
                </VBox.margin>
            </HBox>
         <HBox alignment="CENTER_LEFT" layoutX="50.0" layoutY="211.0" spacing="30.0">
            <children>
               <Label text="Confirm    " />
               <PasswordField fx:id="passwordConfirmField" />
            </children>
         </HBox>
         <Label fx:id="errorFeedbackLabel" />
            <Button fx:id="registerBtn" contentDisplay="CENTER" mnemonicParsing="false" onAction="#register" prefHeight="26.0" prefWidth="173.0" text="Register">
                <VBox.margin>
                    <Insets top="20.0" />
                </VBox.margin>
            </Button>
        </children>
        <padding>
            <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
        </padding>
    </VBox>
    <Button fx:id="haveLoginBtn" layoutX="1090.0" layoutY="728.0" mnemonicParsing="false" onAction="#goToLogin" prefHeight="26.0" prefWidth="133.0" text="I Have Login" textAlignment="CENTER" />
</AnchorPane>
