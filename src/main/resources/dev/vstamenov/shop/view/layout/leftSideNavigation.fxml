<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--<?import org.kordamp.ikonli.javafx.FontIcon?>-->

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0"
      prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.vstamenov.shop.controller.layout.LeftSideNavigation">
    <Label text="Naviagtion">
        <font>
            <Font name="System Bold" size="15.0"/>
        </font>
    </Label>
    <Separator>
        <VBox.margin>
            <Insets left="-20.0" right="-20.0"/>
        </VBox.margin>
    </Separator>
    <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0">
        <Label text="Main">
            <font>
                <Font name="System Bold" size="12.0"/>
            </font>
        </Label>
        <Button onAction="#allSells" maxWidth="-Infinity" mnemonicParsing="false" text="All Sells"/>

        <opaqueInsets>
            <Insets top="100.0"/>
        </opaqueInsets>
    </VBox>

    <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0">
        <Label text="Category">
            <font>
                <Font name="System Bold" size="12.0"/>
            </font>
        </Label>
    </VBox>
    <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0">
        <Label text="Other">
            <font>
                <Font name="System Bold" size="12.0"/>
            </font>
        </Label>
        <Button fx:id="mySells" onAction="#listMySells" accessibleRole="MENU_ITEM" mnemonicParsing="false" text="My sells"/>
        <Button fx:id="addSellBtn" onAction="#addSell" accessibleRole="MENU_ITEM" mnemonicParsing="false" text="add sell" />
        <Button accessibleRole="MENU_ITEM" mnemonicParsing="false" text="Purchases">

            <!--               <graphic>-->
            <!--                  <FontIcon iconLiteral="ci-box" iconSize="64"/>-->
            <!--               </graphic>-->
        </Button>
    </VBox>

    <Button fx:id="logoutBtn" mnemonicParsing="false" onAction="#logout" text="Logout" VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets top="250.0"/>
        </VBox.margin>
    </Button>


    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
</VBox>
